{
  "rules": {
    "demoRequests": {
      // 🔓 Allow public visitors to submit demo and portal access requests
      ".write": "true",
      // 🔒 Only logged-in users/admins can read demo requests
      ".read": "auth != null"
    },
    "users": {
      "$uid": {
        // 🔒 Allow authenticated accounts to read and write user account data
        ".read": "auth != null",
        ".write": "auth != null",
        
        // ⚡ Database Indexes for High-Performance Queries
        "lrReports": {
          ".indexOn": ["clientId", "transporterId", "truckNumber", "date"]
        },
        "payments": {
          ".indexOn": ["clientId"]
        },
        "invoices": {
          ".indexOn": ["clientId"]
        },
        "reminders": {
          ".indexOn": ["dueDate"]
        },
        "vehicles": {
          ".indexOn": ["vehicleNumber"]
        },
        "money_transactions": {
          ".indexOn": ["timestamp"]
        },
        "driverSalaryPayments": {
          ".indexOn": ["vehicleNumber"]
        },
        "transporterPayments": {
          ".indexOn": ["transporterId"]
        },
        "tyres": {
          ".indexOn": ["number"]
        }
      }
    },
    "payments": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["userId"]
    }
  }
}
