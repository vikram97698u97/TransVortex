# =========================================================================
# 🔐 TRANSVORTEX ENVIRONMENT CONFIGURATION TEMPLATE (.env.example)
#
# INSTRUCTIONS:
# 1. Copy this file to '.env' in your local root directory
# 2. Fill in your actual credentials (DO NOT commit '.env' to version control)
# 3. Run 'node build-config.js' to update configurations locally
# =========================================================================

# -------------------------------------------------------------------------
# 🔥 FIREBASE CONFIGURATION
# -------------------------------------------------------------------------
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
FIREBASE_APP_ID=1:your_app_id_here
FIREBASE_MEASUREMENT_ID=G-your_measurement_id_here

# -------------------------------------------------------------------------
# ☁️ CLOUDINARY CONFIGURATION
# -------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_URL=https://api.cloudinary.com/v1_1/your_cloudinary_cloud_name_here/image/upload
CLOUDINARY_BASE_URL=https://res.cloudinary.com/your_cloudinary_cloud_name_here/image/upload

# Cloudinary Upload Presets (e.g. unsigned upload presets)
CLOUDINARY_UPLOAD_PRESET_VEHICLE_DRIVER=vehicle-driver
CLOUDINARY_UPLOAD_PRESET_PAYMENT_BILLING=payment-billing
CLOUDINARY_UPLOAD_PRESET_PROFILE_PIC=profile-pic
CLOUDINARY_UPLOAD_PRESET_DOCUMENTS=documents
CLOUDINARY_UPLOAD_PRESET_RECEIPTS=receipts
CLOUDINARY_UPLOAD_PRESET_EXPENSES=expenses
CLOUDINARY_UPLOAD_PRESET_TYRES=tyres
CLOUDINARY_UPLOAD_PRESET_VEHICLES=vehicles
CLOUDINARY_UPLOAD_PRESET_DRIVERS=drivers
CLOUDINARY_UPLOAD_PRESET_INVOICES=invoices
CLOUDINARY_UPLOAD_PRESET_LR_REPORTS=lr-reports
CLOUDINARY_UPLOAD_PRESET_TRIP_EXPENSES=trip-expenses

# -------------------------------------------------------------------------
# ✉️ EMAILJS CONFIGURATION
# -------------------------------------------------------------------------
EMAILJS_SERVICE_ID=your_emailjs_service_id_here
EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here
EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here

# -------------------------------------------------------------------------
# 🌍 ENVIRONMENT & API SETTINGS
# -------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
API_BASE_URL=http://localhost:3000
VERSION=1.0.0

# -------------------------------------------------------------------------
# 🔒 SECURITY SECRETS (Keep these highly confidential)
# -------------------------------------------------------------------------
SESSION_SECRET=generate_a_long_random_session_secret_string
JWT_SECRET=generate_a_long_random_jwt_secret_string
ENCRYPTION_KEY=generate_a_long_random_encryption_key_string
API_RATE_LIMIT=100
CORS_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://transvortex.online
